{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["agents"],
  "properties": {
    "interval": { "type": "number", "minimum": 5 },
    "screenshotDelay": { "type": "number", "minimum": 1000 },
    "notificationChannel": { "type": "string" },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "url", "enabled"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "usageSelector": { "type": "string" },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
